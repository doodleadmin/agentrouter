[Unit]
Description=Agent Mission Control — Telegram Bot
After=network-online.target agentrouter-api.service
Wants=network-online.target

[Service]
Type=simple
User=agentmc
Group=agentmc
WorkingDirectory=/opt/agent-control/agentrouter/apps/telegram-bot
EnvironmentFile=/opt/agent-control/agentrouter/.env
ExecStart=/opt/agent-control/agentrouter/apps/telegram-bot/.venv/bin/python -m app.main
Restart=on-failure
RestartSec=5

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/opt/agent-control/agentrouter/logs
ProtectHome=true

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=agentrouter-bot

[Install]
WantedBy=multi-user.target
