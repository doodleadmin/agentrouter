FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /workspace

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
       bash \
       git \
    && rm -rf /var/lib/apt/lists/*

# Non-root user for sandbox command execution
RUN addgroup --system sandboxgroup \
    && adduser --system --ingroup sandboxgroup --home /home/sandboxuser sandboxuser

USER sandboxuser

# Minimal healthcheck: runtime availability only, no external calls
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD python -c "print('sandbox-ready')" || exit 1

# Placeholder default command for WRK-03 integration (no autonomous execution here)
CMD ["python", "-c", "print('Agent sandbox image ready for WRK-03; no tasks executed by default.')"]
