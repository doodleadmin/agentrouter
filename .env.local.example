# TG-04: Local environment overrides — NEVER commit real values.
# Copy to .env.local and fill in your test credentials.
#
# This file IS tracked (placeholders only).
# .env.local is gitignored (*.local).

# Required: Telegram Bot API token (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# Required: your Telegram user ID for admin actions (comma-separated)
TELEGRAM_ADMIN_USER_IDS=

# Required: HMAC secret shared with API for callback_data signing
CALLBACK_SECRET=

# Optional defaults (change only if needed):
# API_BASE_URL=http://127.0.0.1:8000
# API_TIMEOUT_SECONDS=10.0

# Optional: restrict to specific chat/topic (0 = any):
# TELEGRAM_CHAT_ID=
# TELEGRAM_TOPIC_ID=
