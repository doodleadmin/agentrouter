# Agent Mission Control — Environment Variables
#
# Copy to .env and fill in real values:
#   cp .env.example .env && chmod 600 .env
#
# NEVER commit .env to git!
# This file uses CHANGE_ME placeholders for required secrets.

# --- Core ---
DEBUG=false
SQL_ECHO=false

# --- Database ---
# For systemd/bare-metal:  postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DB
# For Docker Compose:       postgresql+asyncpg://USER:PASSWORD@postgres:5432/DB
DATABASE_URL=postgresql+asyncpg://CHANGE_ME:CHANGE_ME@127.0.0.1:5432/agentrouter
POSTGRES_DB=agentrouter
POSTGRES_USER=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME

# --- Redis ---
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# --- Telegram ---
# Get bot token from @BotFather
TELEGRAM_BOT_TOKEN=CHANGE_ME
# Comma-separated Telegram user IDs with admin access
TELEGRAM_ADMIN_USER_IDS=CHANGE_ME
# HMAC secret for callback_data signing (generate with: openssl rand -hex 32)
CALLBACK_SECRET=CHANGE_ME
# WebApp URL — shown as launch button in /start when set
# Leave empty to disable Mini App button (polling-only mode)
# Example: https://polyrouter.ru/app/
TELEGRAM_WEBAPP_URL=

# --- API ---
API_BASE_URL=http://127.0.0.1:8000
HOST=127.0.0.1
PORT=8000

# --- Production (Caddy / TLS) ---
AGENTROUTER_DOMAIN=example.com
AGENTROUTER_TLS_EMAIL=admin@example.com
